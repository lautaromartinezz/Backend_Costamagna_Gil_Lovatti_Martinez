# ===========================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================
PORT=3000

# ===========================
# BASE DE DATOS
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nombre_base_datos
DB_USER=usuario_db
DB_PASSWORD=password_db

# ===========================
# AUTENTICACIÓN JWT
# ===========================
# IMPORTANTE: Genera una clave secreta fuerte y única
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_clave_secreta_super_segura_aqui

# Tiempo de expiración del token (ejemplo: 1h, 7d, 30d)
JWT_EXPIRES_IN=24h

# ===========================
# SERVICIO DE EMAIL (RESEND)
# ===========================
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_123456789_tu_api_key_aqui

# Email del remitente verificado
EMAIL_FROM=noreply@tudominio.com

# ===========================
# FRONTEND
# ===========================
FRONTEND_URL=http://localhost:5173

# ===========================
# ENTORNO
# ===========================
NODE_ENV=development

