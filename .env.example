# ===========================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================
PORT=3000

# ===========================
# BASE DE DATOS
# ===========================
# Si usas Docker con Percona Server, el puerto es 3307
# Para MySQL local estándar, usa 3306
DB_HOST=localhost
DB_PORT=3307
DB_NAME=nombre_base_datos
DB_USER=tu_usuario
DB_PASSWORD=tu_password_seguro

# Para el contenedor Docker del proyecto:
# DB_NAME=gestortorneos
# DB_USER y DB_PASSWORD deben coincidir con las variables MYSQL_USER y MYSQL_PASSWORD del contenedor

# ===========================
# AUTENTICACIÓN JWT
# ===========================
# IMPORTANTE: Genera una clave secreta fuerte y única
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_clave_secreta_super_segura_aqui

# Tiempo de expiración del token (ejemplo: 1h, 7d, 30d)
JWT_EXPIRES_IN=24h

# ===========================
# SERVICIO DE EMAIL (GMAIL SMTP)
# ===========================
# Opción gratuita sin necesidad de comprar dominio
#
# PASOS PARA CONFIGURAR GMAIL:
# 1. Necesitas una cuenta de Gmail
# 2. Habilita la verificación en 2 pasos en tu cuenta Google
# 3. Ve a https://myaccount.google.com/apppasswords
# 4. Genera una "Contraseña de aplicación" para "Correo"
# 5. Usa esa contraseña de 16 caracteres aquí
#
# Más info: https://support.google.com/accounts/answer/185833

# Tu correo Gmail (ejemplo: tunombre@gmail.com)
GMAIL_USER=tunombre@gmail.com

# Contraseña de aplicación de 16 caracteres
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email del remitente (puede ser cualquier email válido)
EMAIL_FROM=noreply@gmail.com

# Configuración legacy (Resend) - ya no necesaria
# RESEND_API_KEY=re_123456789_tu_api_key_aqui

# ===========================
# FRONTEND
# ===========================
FRONTEND_URL=http://localhost:5173

# ===========================
# ENTORNO
# ===========================
NODE_ENV=development

